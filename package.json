    "perf:report": "node scripts/generate-baseline-report.js",
    "perf:audit": "bash scripts/performance-audit.sh",
    "perf:budget": "node scripts/check-performance-budget.js",
    "perf:check": "node scripts/check-bundle-size.js",
    "perf:full": "npm run build:optimize && npm run perf:audit",
